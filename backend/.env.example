# Server Configuration
PORT=8000
NODE_ENV=production

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=CREDIT

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_minimum_32_chars

# Redis Configuration
REDIS_URL=redis://localhost:6379

# SMS Gateway (MSG91)
MSG91_API_KEY=your_msg91_api_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=your_msg91_sender_id

# Email / OTP delivery
# auto = use free Ethereal (demo inbox link) if EMAIL_* look like placeholders; else Gmail
# ethereal | gmail = force one provider
OTP_MAIL_MODE=auto
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
# Temporary local fallback: returns/stores debug email OTP even when SMTP fails.
ALLOW_EMAIL_OTP_FALLBACK=false

# ML Scoring (Winner Upgrade v5)
# Optional override for Python executable used by Node ML bridge.
ML_PYTHON_BIN=python3
# Optional timeout in milliseconds for a single inference request.
ML_INFERENCE_TIMEOUT_MS=10000
# Optional overrides if manifest/artifact are moved.
ML_MANIFEST_PATH=models/integration_contracts/winner_upgrade_v5/winner_v5_serving_manifest.json
ML_ARTIFACT_PATH=models/integration_contracts/winner_upgrade_v5/winner_v5_serving_artifact.pkl

# Ollama — Local LLM for RAG Copilot
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_MS=120000
