# Copy this file to .env.docker and fill values

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/credit?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_min_32_chars

EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password

MSG91_API_KEY=optional_or_dummy_for_non_sms_flow
MSG91_TEMPLATE_ID=optional_or_dummy_for_non_sms_flow

# If frontend and backend are served from same domain via nginx proxy (/api), this can be that domain
ALLOWED_ORIGINS=http://localhost

ML_INFERENCE_TIMEOUT_MS=10000
ML_MANIFEST_PATH=models/integration_contracts/winner_upgrade_v5/winner_v5_serving_manifest.json
ML_ARTIFACT_PATH=models/integration_contracts/winner_upgrade_v5/winner_v5_serving_artifact.pkl
